{
  "name": "dashboard-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Modern React dashboard template — TanStack Router, SWR, Zustand, Zod, shadcn/Tailwind. Pairs with dashboard-backend.",
  "scripts": {
    "dev": "vite",
    "generate": "tsr generate",
    "build": "tsr generate && tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsr generate && tsc --noEmit",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "tsr generate && vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "recharts": "^3.9.0",
    "sonner": "^2.0.7",
    "swr": "^2.4.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-cli": "^1.167.17",
    "@tanstack/router-plugin": "^1.168.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "happy-dom": "^20.10.6",
    "msw": "^2.14.6",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
